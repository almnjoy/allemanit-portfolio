---
import Base from '../layouts/Base.astro';
// General "get in touch". Primary funnel = madeformeai signup. Email form → n8n → duallema@quickitprojects.com.
const CONTACT_WEBHOOK = 'https://n8n.quickitprojects.com/webhook/contact';
const SIGNUP_URL = 'https://madeformeai.com/signup';
---
<Base title="Get in touch — Dustin Alleman" description="Want your own AI? Try it free. Or just send me a note.">
  <section class="container-x py-16">
    <div class="mx-auto max-w-xl">

      <!-- PRIMARY: the funnel -->
      <div class="rounded-2xl border border-brand-orange/30 bg-gradient-to-br from-brand-orange/10 to-transparent p-7">
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl">Want your own AI? <span class="text-brand-orange">Free to try.</span></h1>
        <p class="mt-3 text-white/70">Create a free account and you're in a live demo in minutes. No card, no setup.</p>
        <ul class="mt-5 space-y-2 text-sm text-white/75">
          <li class="flex items-start gap-2"><span class="text-brand-orange">✓</span> A free Live AI to explore your ideas</li>
          <li class="flex items-start gap-2"><span class="text-brand-orange">✓</span> The Discord community, including me</li>
        </ul>
        <a href={SIGNUP_URL} target="_blank" rel="noopener" class="btn btn-primary mt-6 w-full text-base">Try your own AI, free →</a>
      </div>

      <!-- SECONDARY: just email me -->
      <div class="mt-8">
        <h2 class="text-lg font-bold text-white">Just want to reach me?</h2>
        <p class="mt-1 text-sm text-white/55">No funnel, no bot. This sends straight to my inbox (<span class="text-white/75">duallema@quickitprojects.com</span>) and I read every one.</p>

        <form id="contact-form" class="card mt-5 space-y-4 p-6" data-webhook={CONTACT_WEBHOOK}>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block text-sm font-semibold text-white">Name</label>
              <input name="name" placeholder="Your name"
                class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange" />
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-semibold text-white">Email <span class="text-brand-orange">*</span></label>
              <input name="email" type="email" required placeholder="you@email.com"
                class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange" />
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-semibold text-white">Message <span class="text-brand-orange">*</span></label>
            <textarea name="message" rows="4" required placeholder="What's up?"
              class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange"></textarea>
          </div>
          <button type="submit" class="btn btn-ghost w-full">Send it →</button>
          <p id="contact-msg" class="hidden text-center text-sm"></p>
        </form>
      </div>

      <!-- QUICK IT (work + AI line, one box) -->
      <div class="card mt-8 p-6">
        <div class="text-base font-bold text-white">🖧 Work with me · Quick IT</div>
        <p class="mt-1 text-sm text-white/60">IT, networking, infrastructure, automation. Call the AI line for a quick setup game, or just say "sign up." :)</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <a href="tel:+15178834473" class="btn btn-primary !py-2 !px-4 text-sm">(517) 883-4473</a>
          <a href="https://quickitprojects.com/start" target="_blank" rel="noopener" class="btn btn-ghost !py-2 !px-4 text-sm">Start online</a>
          <a href="https://quickitprojects.com" target="_blank" rel="noopener" class="btn btn-ghost !py-2 !px-4 text-sm">Quick IT Projects →</a>
        </div>
      </div>

      <p class="mt-8 text-center text-sm text-white/50">Here for the Plex server? <a href="/status" class="text-brand-orange hover:underline">Media &amp; access →</a></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    const msg = document.getElementById('contact-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      const data = new FormData(form);
      const email = (data.get('email') || '').toString().trim();
      const message = (data.get('message') || '').toString().trim();
      if (!email || !message) { show('Email and a message, please.', true); return; }
      const payload = {
        name: (data.get('name') || '').toString().trim(),
        email,
        message,
        source: 'allemanit.com/contact',
        submittedAt: new Date().toISOString(),
      };
      btn.disabled = true; btn.textContent = 'Sending...';
      try {
        const res = await fetch(form.dataset.webhook, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('bad status');
        form.reset(); show('Got it. I read every message and will get back to you.', false);
      } catch (err) {
        show('Something broke. Email me directly at duallema@quickitprojects.com.', true);
      } finally {
        btn.disabled = false; btn.textContent = 'Send it →';
      }
    });
    function show(text, isError) {
      msg.textContent = text;
      msg.className = 'text-center text-sm ' + (isError ? 'text-red-400' : 'text-green-400');
    }
  </script>
</Base>
