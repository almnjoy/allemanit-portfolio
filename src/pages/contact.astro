---
import Base from '../layouts/Base.astro';
// TODO: confirm this n8n webhook exists / create it. Lab+media+nextcloud access requests POST here.
const WEBHOOK_URL = 'https://n8n.allemanit.com/webhook/75d927ed-c714-44b0-aa7c-00c909d1a7b3';
---
<Base title="Request Access — AllemanIT" description="Request access to the AllemanIT home lab, media server, or Nextcloud.">
  <section class="container-x py-16">
    <div class="mx-auto max-w-xl">
      <div class="card mb-8 p-6">
        <h2 class="text-lg font-bold text-white">Business inquiry? Call my AI line.</h2>
        <p class="mt-1 text-sm text-white/65">Call my AI line for a fun AI game to sign up. Just say "sign up" if you don't want to play. :)</p>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <a href="tel:+15178834473" class="btn btn-primary text-sm">(517) 883-4473</a>
          <a href="https://quickitprojects.com/start" target="_blank" rel="noopener" class="btn btn-ghost text-sm">Start online</a>
        </div>
      </div>

      <h1 class="text-4xl font-extrabold text-white">Request Access</h1>
      <p class="mt-3 text-white/65">The form below is for home lab, media, or Nextcloud access. Submit once for any services you want. I review and follow up by email if approved.</p>

      <form id="access-form" class="card mt-8 space-y-5 p-7" data-webhook={WEBHOOK_URL}>
        <div>
          <label class="mb-1.5 block text-sm font-semibold text-white">Full Name <span class="text-brand-orange">*</span></label>
          <input name="fullName" required placeholder="Enter your name"
            class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange" />
        </div>
        <div>
          <label class="mb-1.5 block text-sm font-semibold text-white">Email Address <span class="text-brand-orange">*</span></label>
          <input name="email" type="email" required placeholder="Enter your email"
            class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-white">Access Desired <span class="text-brand-orange">*</span></label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 text-white/80"><input type="checkbox" name="access" value="Lab Access" class="h-4 w-4 accent-brand-orange" /> Lab Access</label>
            <label class="flex items-center gap-3 text-white/80"><input type="checkbox" name="access" value="Media (Plex)" class="h-4 w-4 accent-brand-orange" /> Media Access (Plex videos / music)</label>
            <label class="flex items-center gap-3 text-white/80"><input type="checkbox" name="access" value="Nextcloud" class="h-4 w-4 accent-brand-orange" /> Nextcloud</label>
          </div>
        </div>
        <div>
          <label class="mb-1.5 block text-sm font-semibold text-white">Notes</label>
          <textarea name="notes" rows="4" placeholder="Anything else you'd like to add"
            class="w-full rounded-xl border border-white/10 bg-ink-800 px-4 py-3 text-white placeholder-white/30 outline-none focus:border-brand-orange"></textarea>
        </div>
        <button type="submit" class="btn btn-primary w-full">Request Access</button>
        <p id="form-msg" class="hidden text-center text-sm"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('access-form');
    const msg = document.getElementById('form-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      const data = new FormData(form);
      const access = data.getAll('access');
      if (access.length === 0) { show('Pick at least one service.', true); return; }
      const payload = {
        fullName: data.get('fullName'),
        email: data.get('email'),
        access,
        notes: data.get('notes'),
        source: 'allemanit.com',
        submittedAt: new Date().toISOString(),
      };
      btn.disabled = true; btn.textContent = 'Sending...';
      try {
        const res = await fetch(form.dataset.webhook, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('bad status');
        form.reset(); show('Request received. I will follow up by email.', false);
      } catch (err) {
        show('Something went wrong. Email hello@quickitprojects.com and I will sort it.', true);
      } finally {
        btn.disabled = false; btn.textContent = 'Request Access';
      }
    });
    function show(text, isError) {
      msg.textContent = text;
      msg.className = 'text-center text-sm ' + (isError ? 'text-red-400' : 'text-green-400');
    }
  </script>
</Base>
