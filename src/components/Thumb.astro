---
const { image, alt = '' } = Astro.props;
---
{image ? (
  <img src={image} alt={alt} class="aspect-video w-full rounded-xl border border-white/10 object-cover" />
) : (
  <div class="flex aspect-video w-full items-center justify-center rounded-xl border border-dashed border-white/15 bg-white/[0.02]">
    <div class="flex flex-col items-center gap-2 opacity-40">
      <img src="/logo-mark.png" alt="" class="h-8 w-8" />
      <span class="text-xs text-white/50">Screenshot coming</span>
    </div>
  </div>
)}
