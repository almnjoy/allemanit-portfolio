---
import Base from '../layouts/Base.astro';

// Daily: dashboard-style running blog. Reads live from n8n webhooks (curated by Dustin / agents).
// Contract:
//   GET daily-log      -> { posts:    [ { id, title?, body, tags?[], at (ISO) } ] }  newest first
//   GET daily-projects -> { projects: [ { name, status, note?, pct?, updated? } ] }  status: building|live|paused|shipped
//   GET daily-news     -> { news:     [ { title, url, source?, note?, at? } ] }      newest first
const LOG_WEBHOOK = 'https://n8n.quickitprojects.com/webhook/daily-log';
const PROJECTS_WEBHOOK = 'https://n8n.quickitprojects.com/webhook/daily-projects';
const NEWS_WEBHOOK = 'https://n8n.quickitprojects.com/webhook/daily-news';
---
<Base title="Daily — Dustin Alleman" description="Dustin's running log: thoughts, builds, and signal. Updated as it happens.">
  <section class="dz">

    <!-- HEADER -->
    <div class="container-x head">
      <div class="head-l">
        <div class="kicker"><span class="dot"></span> LIVE LOG</div>
        <h1>DAILY</h1>
        <p class="tag-line">Running log of what I'm building, thinking, and tracking. No filter, no schedule. It just gets updated.</p>
      </div>
      <div class="head-r">
        <div class="stat"><span class="mono" id="today">—</span><small>today</small></div>
        <div class="stat"><span class="mono" id="count">—</span><small>entries</small></div>
        <div class="stat"><span class="mono" id="last">—</span><small>last drop</small></div>
      </div>
    </div>

    <!-- GRID -->
    <div class="container-x grid">

      <!-- MAIN: LOG FEED -->
      <div class="col-main">
        <div class="col-head">
          <h2>The log</h2>
          <div id="filters" class="filters"></div>
        </div>
        <div id="log" class="log">
          <div class="skel"></div><div class="skel"></div><div class="skel"></div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="col-side">

        <div class="widget">
          <div class="w-head"><h3>Building now</h3><span class="w-tag">projects</span></div>
          <div id="projects" class="projects"><p class="empty">Loading…</p></div>
        </div>

        <div class="widget">
          <div class="w-head"><h3>Signal</h3><span class="w-tag">what I'm reading</span></div>
          <div id="news" class="news"><p class="empty">Loading…</p></div>
        </div>

        <div class="widget links">
          <div class="w-head"><h3>Elsewhere</h3></div>
          <a href="/music">🎧 What I'm listening to</a>
          <a href="/status">📺 Media / homelab status</a>
          <a href="https://almnjoy.dev" target="_blank" rel="noopener">✍ Long-form blog ↗</a>
          <a href="/projects">🛠 Projects ↗</a>
        </div>

      </aside>
    </div>

    <p class="foot-note container-x">Homelab-hosted · curated by hand + a little automation · <a href="/">allemanit.com</a></p>
  </section>

  <script define:vars={{ LOG_WEBHOOK, PROJECTS_WEBHOOK, NEWS_WEBHOOK }}>
    const qs = new URLSearchParams(location.search);
    const DEMO = qs.get('demo') === '1';

    // ---------- helpers ----------
    function esc(s) {
      return (s == null ? '' : String(s)).replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
      ));
    }
    // light markdown-ish: escape, then linkify, **bold**, `code`, newlines
    function rich(s) {
      let t = esc(s);
      t = t.replace(/(https?:\/\/[^\s<]+)/g, (u) => `<a href="${u}" target="_blank" rel="noopener">${u.replace(/^https?:\/\//, '')}</a>`);
      t = t.replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>');
      t = t.replace(/`([^`]+)`/g, '<code>$1</code>');
      t = t.replace(/\n/g, '<br>');
      return t;
    }
    function timeAgo(iso) {
      if (!iso) return '';
      const d = new Date(iso); if (isNaN(d)) return '';
      const s = Math.floor((Date.now() - d.getTime()) / 1000);
      if (s < 60) return 'just now';
      const m = Math.floor(s / 60); if (m < 60) return m + 'm ago';
      const h = Math.floor(m / 60); if (h < 24) return h + 'h ago';
      const dd = Math.floor(h / 24); if (dd < 7) return dd + 'd ago';
      return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    }
    function dstamp(iso) {
      const d = iso ? new Date(iso) : null;
      if (!d || isNaN(d)) return '';
      return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // ---------- demo data ----------
    const DEMO_LOG = [
      { id: 3, title: 'Shipped the /music page', body: 'Public music page is live at **allemanit.com/music** — funk-bass hero, Spotify embeds, a rec form wired to n8n. Rebuilt the deploy so pushing source is enough.', tags: ['builds', 'web'], at: new Date(Date.now() - 2 * 3600e3).toISOString() },
      { id: 2, title: 'CML lab + BGP reflectors', body: 'Spun a fresh `Cisco Modeling Labs` topology to sanity-check a route-reflector design before I touch prod. Two RRs, full mesh underneath, clean.', tags: ['net', 'labs'], at: new Date(Date.now() - 26 * 3600e3).toISOString() },
      { id: 1, body: 'Note to self: the n8n Form/Wait node keys output by LABEL not fieldName. Cost me an hour on an approval gate. Writing it down so I stop re-learning it.', tags: ['n8n', 'gotcha'], at: new Date(Date.now() - 3 * 86400e3).toISOString() },
    ];
    const DEMO_PROJECTS = [
      { name: 'AllemanIT site', status: 'building', note: 'music + daily pages, footer nav cleanup', pct: 70, updated: new Date(Date.now() - 2 * 3600e3).toISOString() },
      { name: 'MadeForMeAI', status: 'live', note: 'dashboard-api carved out, running on worker2', pct: 100 },
      { name: 'Fleet HQ', status: 'building', note: 'one dashboard for all the agents', pct: 35 },
      { name: 'Spotify auto-sort', status: 'paused', note: 'blocked on dev-mode 403', pct: 80 },
    ];
    const DEMO_NEWS = [
      { title: 'Something worth reading about BGP', url: 'https://example.com/bgp', source: 'blog', note: 'good breakdown of RR scaling', at: new Date(Date.now() - 5 * 3600e3).toISOString() },
      { title: 'AI agent framework release', url: 'https://example.com/agents', source: 'gh', at: new Date(Date.now() - 30 * 3600e3).toISOString() },
    ];

    async function grab(url, key, demo) {
      if (DEMO) return demo;
      try {
        const r = await fetch(url, { cache: 'no-store' });
        const j = await r.json();
        return (j && j[key]) || [];
      } catch (e) { return null; }
    }

    // ---------- render: log ----------
    let ALL = [];
    let activeTag = null;
    const logEl = document.getElementById('log');
    const filtersEl = document.getElementById('filters');

    function renderLog() {
      const posts = activeTag ? ALL.filter((p) => (p.tags || []).includes(activeTag)) : ALL;
      if (!posts.length) {
        logEl.innerHTML = '<div class="empty-card">Nothing logged yet. First drop is coming.</div>';
        return;
      }
      logEl.innerHTML = posts.map((p) => (
        '<article class="entry">' +
          '<div class="entry-rail"><span class="node"></span></div>' +
          '<div class="entry-body">' +
            '<div class="entry-meta"><span class="mono">' + esc(dstamp(p.at)) + '</span>' +
              '<span class="ago">' + esc(timeAgo(p.at)) + '</span></div>' +
            (p.title ? '<h3>' + esc(p.title) + '</h3>' : '') +
            '<div class="entry-text">' + rich(p.body || '') + '</div>' +
            ((p.tags && p.tags.length) ? '<div class="chips">' + p.tags.map((t) =>
              '<button class="chip" data-tag="' + esc(t) + '">#' + esc(t) + '</button>').join('') + '</div>' : '') +
          '</div>' +
        '</article>'
      )).join('');
      logEl.querySelectorAll('.chip').forEach((c) => c.addEventListener('click', () => setTag(c.dataset.tag)));
    }
    function renderFilters() {
      const tags = [...new Set(ALL.flatMap((p) => p.tags || []))];
      if (!tags.length) { filtersEl.innerHTML = ''; return; }
      filtersEl.innerHTML =
        '<button class="chip' + (activeTag ? '' : ' on') + '" data-tag="">all</button>' +
        tags.map((t) => '<button class="chip' + (activeTag === t ? ' on' : '') + '" data-tag="' + esc(t) + '">#' + esc(t) + '</button>').join('');
      filtersEl.querySelectorAll('.chip').forEach((c) => c.addEventListener('click', () => setTag(c.dataset.tag || null)));
    }
    function setTag(t) { activeTag = t; renderFilters(); renderLog(); }

    // ---------- render: projects ----------
    function renderProjects(list) {
      const el = document.getElementById('projects');
      if (list === null) { el.innerHTML = '<p class="empty">Couldn\'t load projects.</p>'; return; }
      if (!list.length) { el.innerHTML = '<p class="empty">No active projects listed.</p>'; return; }
      el.innerHTML = list.map((p) => {
        const st = (p.status || 'building').toLowerCase();
        const pct = Math.max(0, Math.min(100, Number(p.pct) || 0));
        return '<div class="proj">' +
          '<div class="proj-top"><b>' + esc(p.name) + '</b><span class="pill ' + esc(st) + '">' + esc(st) + '</span></div>' +
          (p.note ? '<p>' + esc(p.note) + '</p>' : '') +
          (p.pct != null ? '<div class="bar"><span style="width:' + pct + '%"></span></div>' : '') +
        '</div>';
      }).join('');
    }

    // ---------- render: news ----------
    function renderNews(list) {
      const el = document.getElementById('news');
      if (list === null) { el.innerHTML = '<p class="empty">Couldn\'t load signal.</p>'; return; }
      if (!list.length) { el.innerHTML = '<p class="empty">Nothing pinned right now.</p>'; return; }
      el.innerHTML = list.map((n) => (
        '<a class="nitem" href="' + esc(n.url || '#') + '" target="_blank" rel="noopener">' +
          '<div class="ntitle">' + esc(n.title) + ' <span class="arr">↗</span></div>' +
          '<div class="nmeta">' + (n.source ? '<span class="src">' + esc(n.source) + '</span>' : '') +
            (n.at ? '<span class="mono">' + esc(timeAgo(n.at)) + '</span>' : '') + '</div>' +
          (n.note ? '<div class="nnote">' + esc(n.note) + '</div>' : '') +
        '</a>'
      )).join('');
    }

    // ---------- header stats ----------
    function stats() {
      document.getElementById('today').textContent = new Date().toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      document.getElementById('count').textContent = ALL.length ? String(ALL.length) : '0';
      document.getElementById('last').textContent = ALL.length ? timeAgo(ALL[0].at) : '—';
    }

    // ---------- boot ----------
    (async () => {
      const [log, projects, news] = await Promise.all([
        grab(LOG_WEBHOOK, 'posts', DEMO_LOG),
        grab(PROJECTS_WEBHOOK, 'projects', DEMO_PROJECTS),
        grab(NEWS_WEBHOOK, 'news', DEMO_NEWS),
      ]);
      ALL = Array.isArray(log) ? log : [];
      renderFilters(); renderLog(); stats();
      renderProjects(projects);
      renderNews(news);
    })();
  </script>

  <style is:global>
    .dz {
      --blue: #4f9dff; --orange: #ff8a3d; --line: rgba(255,255,255,0.09);
      --ok: #35d07f; --warn: #f7a23b; --mute: #8a94a6;
      color: #e7ecf3;
    }
    .dz .mono { font-family: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace; }

    /* HEADER */
    .dz .head { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; padding: 40px 0 26px; flex-wrap: wrap; }
    .dz .kicker {
      display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 800; letter-spacing: 0.22em;
      color: var(--blue); text-transform: uppercase; margin-bottom: 10px;
    }
    .dz .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--ok); box-shadow: 0 0 0 0 rgba(53,208,127,0.7); animation: dz-pulse 2s infinite; }
    @keyframes dz-pulse { 0% { box-shadow: 0 0 0 0 rgba(53,208,127,0.6); } 70% { box-shadow: 0 0 0 7px rgba(53,208,127,0); } 100% { box-shadow: 0 0 0 0 rgba(53,208,127,0); } }
    .dz .head-l h1 { font-size: clamp(44px, 8vw, 86px); font-weight: 800; letter-spacing: -0.03em; line-height: 0.9; margin: 0; color: #fff; }
    .dz .tag-line { max-width: 540px; margin: 14px 0 0; color: rgba(231,236,243,0.62); line-height: 1.55; font-size: 15px; }
    .dz .head-r { display: flex; gap: 10px; }
    .dz .stat {
      display: flex; flex-direction: column; align-items: center; gap: 3px; min-width: 78px;
      padding: 12px 14px; border-radius: 14px; border: 1px solid var(--line); background: rgba(255,255,255,0.03);
    }
    .dz .stat .mono { font-size: 20px; font-weight: 700; color: #fff; }
    .dz .stat small { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mute); }

    /* GRID */
    .dz .grid { display: grid; grid-template-columns: 1fr 340px; gap: 26px; align-items: start; padding-bottom: 20px; }
    .dz .col-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; flex-wrap: wrap; }
    .dz .col-head h2 { font-size: 22px; font-weight: 800; color: #fff; margin: 0; }
    .dz .filters { display: flex; flex-wrap: wrap; gap: 7px; }

    .dz .chip {
      font-size: 12px; font-weight: 600; color: rgba(231,236,243,0.7); cursor: pointer;
      border: 1px solid var(--line); background: rgba(255,255,255,0.03); border-radius: 999px; padding: 4px 11px;
      transition: all .13s ease; font-family: inherit;
    }
    .dz .chip:hover { color: #fff; border-color: rgba(79,157,255,0.5); }
    .dz .chip.on { background: var(--blue); color: #04121f; border-color: var(--blue); }

    /* LOG */
    .dz .log { display: flex; flex-direction: column; }
    .dz .entry { display: grid; grid-template-columns: 24px 1fr; gap: 0; }
    .dz .entry-rail { display: flex; flex-direction: column; align-items: center; }
    .dz .node { width: 13px; height: 13px; border-radius: 50%; background: var(--blue); margin-top: 6px; box-shadow: 0 0 0 4px rgba(79,157,255,0.18), 0 0 12px rgba(79,157,255,0.55); flex: none; }
    .dz .entry-rail::after { content: ''; width: 2px; flex: 1; background: linear-gradient(180deg, rgba(79,157,255,0.4), rgba(255,255,255,0.04)); margin-top: 5px; }
    .dz .entry:last-child .entry-rail::after { background: transparent; }
    .dz .entry-body { padding: 0 0 26px 16px; min-width: 0; }
    .dz .entry-meta { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
    .dz .entry-meta .mono { font-size: 12.5px; color: var(--blue); font-weight: 600; }
    .dz .entry-meta .ago { font-size: 11.5px; color: var(--mute); }
    .dz .entry-body h3 { font-size: 18px; font-weight: 700; color: #fff; margin: 0 0 7px; line-height: 1.3; }
    .dz .entry-text { color: rgba(231,236,243,0.82); line-height: 1.6; font-size: 14.5px; word-wrap: break-word; }
    .dz .entry-text a { color: var(--blue); text-decoration: underline; text-underline-offset: 2px; }
    .dz .entry-text code { font-family: ui-monospace, Menlo, monospace; font-size: 12.5px; background: rgba(79,157,255,0.12); color: #bcd8ff; padding: 1px 6px; border-radius: 5px; }
    .dz .entry-text b { color: #fff; }
    .dz .chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 11px; }

    .dz .empty-card, .dz .skel {
      border: 1px solid var(--line); border-radius: 14px; background: rgba(255,255,255,0.02);
    }
    .dz .empty-card { padding: 24px; color: var(--mute); text-align: center; }
    .dz .skel { height: 92px; margin-bottom: 12px; position: relative; overflow: hidden; }
    .dz .skel::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent); animation: dz-sweep 1.4s infinite; }
    @keyframes dz-sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

    /* SIDEBAR */
    .dz .col-side { display: flex; flex-direction: column; gap: 18px; position: sticky; top: 20px; }
    .dz .widget { border: 1px solid var(--line); border-radius: 18px; background: rgba(255,255,255,0.025); padding: 18px; }
    .dz .w-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .dz .w-head h3 { font-size: 15px; font-weight: 800; color: #fff; margin: 0; letter-spacing: -0.01em; }
    .dz .w-tag { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mute); }
    .dz .empty { color: var(--mute); font-size: 13.5px; padding: 4px 0; margin: 0; }

    /* projects */
    .dz .proj { padding: 12px 0; border-top: 1px solid var(--line); }
    .dz .proj:first-child { border-top: 0; padding-top: 0; }
    .dz .proj-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .dz .proj-top b { color: #fff; font-size: 14.5px; flex: 1 1 auto; min-width: 0; }
    .dz .proj p { margin: 6px 0 9px; color: rgba(231,236,243,0.6); font-size: 12.5px; line-height: 1.45; }
    .dz .pill { flex: 0 0 auto; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 9px; border-radius: 999px; white-space: nowrap; border: 1px solid transparent; }
    .dz .pill.building { background: rgba(247,162,59,0.20); color: var(--warn); border-color: rgba(247,162,59,0.35); }
    .dz .pill.live { background: rgba(53,208,127,0.20); color: var(--ok); border-color: rgba(53,208,127,0.35); }
    .dz .pill.shipped { background: rgba(79,157,255,0.20); color: var(--blue); border-color: rgba(79,157,255,0.35); }
    .dz .pill.paused { background: rgba(255,255,255,0.08); color: var(--mute); border-color: rgba(255,255,255,0.14); }
    .dz .bar { height: 5px; border-radius: 999px; background: rgba(255,255,255,0.07); overflow: hidden; }
    .dz .bar span { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--blue), var(--orange)); }

    /* news */
    .dz .nitem { display: block; padding: 11px 0; border-top: 1px solid var(--line); }
    .dz .nitem:first-child { border-top: 0; padding-top: 0; }
    .dz .ntitle { color: #fff; font-size: 13.5px; font-weight: 600; line-height: 1.4; }
    .dz .ntitle .arr { color: var(--blue); font-size: 11px; }
    .dz .nitem:hover .ntitle { color: var(--blue); }
    .dz .nmeta { display: flex; gap: 8px; align-items: center; margin-top: 4px; }
    .dz .nmeta .src { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--orange); font-weight: 700; }
    .dz .nmeta .mono { font-size: 11px; color: var(--mute); }
    .dz .nnote { font-size: 12px; color: rgba(231,236,243,0.55); margin-top: 4px; line-height: 1.4; }

    /* links widget */
    .dz .links a { display: block; padding: 9px 0; color: rgba(231,236,243,0.78); font-size: 13.5px; border-top: 1px solid var(--line); transition: color .13s ease; }
    .dz .links a:first-of-type { border-top: 0; }
    .dz .links a:hover { color: var(--blue); }

    .dz .foot-note { display: block; text-align: center; color: rgba(231,236,243,0.4); font-size: 13px; padding: 30px 0 50px; }
    .dz .foot-note a { color: rgba(231,236,243,0.6); text-decoration: underline; text-underline-offset: 3px; }

    @media (max-width: 900px) {
      .dz .grid { grid-template-columns: 1fr; }
      .dz .col-side { position: static; }
      .dz .head-r { width: 100%; }
    }
  </style>
</Base>
