---
import Editorial from '../layouts/Editorial.astro';

// The Daemon: a living page. Curated tiles are static (edit in this file / later a content collection).
// Engine-fed tiles read these endpoints once the daily engine + n8n flows are wired (see build plan).
const SPOTIFY_STATS = 'https://spotify-stats.allemanit.com/';
const YT = 'https://www.youtube.com/@Almnjoy';
// const LISTENING_API = SPOTIFY_STATS + 'api/now';
// const WATCHING_API  = 'https://n8n.quickitprojects.com/webhook/daily-watching';
// const NEWS_API      = 'https://n8n.quickitprojects.com/webhook/daily-news';
// const UPDATES_API   = 'https://n8n.quickitprojects.com/webhook/daily-log';

const ideas = [
  'The best automation is the one you forget is running.',
  'A homelab that runs like prod teaches you more than any cert.',
  'Most "AI products" are a good prompt and a database. The moat is the workflow.',
  'Your tools should fan out from one source, not live in ten browser tabs.',
];
const goals = [
  'Whole fleet running off one shared brain.',
  'A CCIE-level lab, just to prove I can.',
  'Ship an AI product a stranger pays for without me touching it.',
  'Build a synth from parts.',
];
const questions = [
  "What's the smallest agent that's actually useful every day?",
  'Can a personal site be a real API that AI queries? (this page, eventually)',
  "Where's the line between automating and over-engineering?",
];
const predictions = [
  { t: 'Most SMB "CRMs" get replaced by a chat plus a canvas within a few years.', d: 'Jul 2026' },
  { t: 'Browser-driving agents beat official social APIs for indie posting.', d: 'Jul 2026' },
];
---
<Editorial title="Daily — Dustin Alleman" description="A living page: what I'm building, the ideas I'm chewing on, and what I want to try. Updated as it happens.">
  <div class="ed-mast">
    <a class="ed-name" href="/daily">ALMNJOY <b>DAILY</b></a>
    <div class="ed-meta">Mission · Ideas · Signal — Live</div>
  </div>

  <section class="dm">
    <p class="dm-intro">A running record of what I'm making, what I'm chewing on, and what I want to try next. Some of it I write. Some of it my agents keep current.</p>

    <div class="dm-grid">

      <!-- MISSION -->
      <div class="tile c4 accent">
        <span class="k">Mission</span>
        <p class="lead">Ten years in networking and IT. Cisco in a FedRAMP shop by day; AI agents, automation, and a homelab that runs like production by night. I build because building is the point. Money's a bonus, not the north star.</p>
      </div>

      <!-- BUILDING NOW (engine-fed) -->
      <div class="tile c2 r2">
        <span class="k">Building now</span>
        <span class="live">● live feed soon</span>
        <ul class="stack">
          <li><b>AllemanIT site</b><small>the daily + blog + music rebuild you're looking at</small></li>
          <li><b>Fleet HQ</b><small>one dashboard for every agent I run</small></li>
          <li><b>Shared brain</b><small>git-backed memory across the whole fleet</small></li>
          <li><b>The daily engine</b><small>one post, fanned out to Discord, socials, and here</small></li>
        </ul>
        <p class="soon">This tile fills from the daily engine once it's wired.</p>
      </div>

      <!-- LISTENING -->
      <a class="tile c1 link" href="/music">
        <span class="k">Listening</span>
        <div class="big">🎧</div>
        <p class="soon">Funk-bass, always. The full rotation lives on /music.</p>
        <span class="arr">Open /music →</span>
      </a>

      <!-- WATCHING -->
      <a class="tile c1 link" href={YT} target="_blank" rel="noopener">
        <span class="k">Watching</span>
        <div class="big">📺</div>
        <p class="soon">A feed of what I'm watching, coming online. Meanwhile: my channel.</p>
        <span class="arr">YouTube ↗</span>
      </a>

      <!-- IDEAS -->
      <div class="tile c2">
        <span class="k">Ideas</span>
        <ul class="ideas">
          {ideas.map((i) => (<li>{i}</li>))}
        </ul>
      </div>

      <!-- SIGNAL / NEWS (live) -->
      <div class="tile c2">
        <span class="k">Signal</span>
        <span class="live">● what I'm reading</span>
        <div id="signal" class="signal"><p class="soon">Loading the feed…</p></div>
      </div>

      <!-- GOALS -->
      <div class="tile c2">
        <span class="k">Goals · the fun kind</span>
        <ul class="checks">
          {goals.map((g) => (<li>{g}</li>))}
        </ul>
      </div>

      <!-- QUESTIONS -->
      <div class="tile c2">
        <span class="k">Open questions</span>
        <ul class="q">
          {questions.map((q) => (<li>{q}</li>))}
        </ul>
      </div>

      <!-- PREDICTIONS -->
      <div class="tile c2">
        <span class="k">Predictions</span>
        <ul class="preds">
          {predictions.map((p) => (<li><span class="pt">{p.t}</span><span class="pd">{p.d}</span></li>))}
        </ul>
      </div>

      <!-- CURRENTLY -->
      <div class="tile c1">
        <span class="k">Currently</span>
        <div class="cur"><span>📍</span> Chicago, IL</div>
        <div class="cur"><span>🎧</span> Funk-bass, always</div>
        <div class="cur"><span>🛠</span> Rebuilding this site</div>
      </div>

      <!-- LONG-FORM -->
      <a class="tile c1 link" href="/blog">
        <span class="k">Long-form</span>
        <div class="big">✍</div>
        <p class="soon">The real writeups, when something's worth the room.</p>
        <span class="arr">The Dispatch →</span>
      </a>

    </div>
  </section>

  <script define:vars={{ NEWS_API: 'https://n8n.quickitprojects.com/webhook/daily-news' }}>
    (async () => {
      const el = document.getElementById('signal');
      if (!el) return;
      const esc = (s) => (s == null ? '' : String(s)).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      const ago = (iso) => {
        if (!iso) return '';
        const d = new Date(iso); if (isNaN(d)) return '';
        const s = Math.floor((Date.now() - d.getTime()) / 1000);
        if (s < 3600) return Math.max(1, Math.floor(s / 60)) + 'm ago';
        const h = Math.floor(s / 3600); if (h < 24) return h + 'h ago';
        const dd = Math.floor(h / 24); return dd + 'd ago';
      };
      try {
        const r = await fetch(NEWS_API, { cache: 'no-store' });
        const data = await r.json();
        const items = Array.isArray(data) ? data : (data.news || []);
        if (!items.length) { el.innerHTML = '<p class="soon">Nothing pinned right now.</p>'; return; }
        el.innerHTML = items.slice(0, 6).map((n) => (
          '<a class="sig" href="' + esc(n.url) + '" target="_blank" rel="noopener">' +
            '<span class="st">' + esc(n.title) + '</span>' +
            '<span class="sm"><b>' + esc(n.source) + '</b>' + (ago(n.at) ? ' · ' + ago(n.at) : '') + '</span>' +
          '</a>'
        )).join('');
      } catch (e) {
        el.innerHTML = '<p class="soon">Feed is napping. Refresh in a bit.</p>';
      }
    })();
  </script>

  <style is:global>
    .dm { --accent:#ff6a00; --accent2:#4f9dff; --rule:#2a2721; --mute:#8f8a7d; }
    .dm-intro { font-family:'Spectral',serif; font-size:18px; line-height:1.6; color:#c7c1b3; max-width:60ch; margin:26px 0 26px; }

    .dm-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; grid-auto-flow:dense; }
    .dm .tile {
      grid-column:span 1; border:1px solid var(--rule); border-radius:14px; padding:20px;
      background:rgba(255,255,255,0.02); display:flex; flex-direction:column; min-width:0;
    }
    .dm .c1 { grid-column:span 1; } .dm .c2 { grid-column:span 2; } .dm .c4 { grid-column:span 4; }
    .dm .r2 { grid-row:span 2; }
    .dm .accent { background:linear-gradient(150deg, rgba(255,106,0,0.10), rgba(255,255,255,0.015)); border-color:rgba(255,106,0,0.28); }
    .dm a.link { text-decoration:none; transition:border-color .14s ease, transform .14s ease; }
    .dm a.link:hover { border-color:var(--accent2); transform:translateY(-2px); }

    .dm .k { font-family:'Inter',sans-serif; font-size:11px; font-weight:800; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent); }
    .dm .live { font-family:'Inter',sans-serif; font-size:10.5px; color:#35d07f; letter-spacing:0.06em; margin-top:4px; }
    .dm .soon { font-family:'Inter',sans-serif; font-size:12.5px; color:var(--mute); line-height:1.5; margin-top:auto; padding-top:12px; }
    .dm .u { color:var(--accent2); }
    .dm .arr { font-family:'Inter',sans-serif; font-size:12.5px; font-weight:700; color:var(--accent2); margin-top:10px; }
    .dm .big { font-size:34px; margin:10px 0; }

    .dm .lead { font-family:'Fraunces',serif; font-size:clamp(20px,2.4vw,27px); line-height:1.32; color:#f3eee2; font-weight:500; margin-top:12px; max-width:60ch; }

    .dm .stack { list-style:none; margin:14px 0 0; padding:0; display:flex; flex-direction:column; gap:12px; }
    .dm .stack li { border-left:2px solid var(--accent); padding-left:12px; }
    .dm .stack b { display:block; font-family:'Fraunces',serif; font-size:17px; color:#fff; font-weight:600; }
    .dm .stack small { color:var(--mute); font-size:12.5px; }

    .dm ul.ideas, .dm ul.checks, .dm ul.q, .dm ul.preds { list-style:none; margin:14px 0 0; padding:0; display:flex; flex-direction:column; gap:11px; }
    .dm ul.ideas li { font-family:'Spectral',serif; font-size:15.5px; line-height:1.5; color:#d8d2c4; padding-left:18px; position:relative; }
    .dm ul.ideas li::before { content:'—'; position:absolute; left:0; color:var(--accent); }
    .dm ul.checks li { font-size:14px; color:#d8d2c4; padding-left:24px; position:relative; }
    .dm ul.checks li::before { content:'○'; position:absolute; left:0; color:var(--accent2); font-size:13px; }
    .dm ul.q li { font-family:'Spectral',serif; font-style:italic; font-size:15px; line-height:1.5; color:#cfc9bb; padding-left:18px; position:relative; }
    .dm ul.q li::before { content:'?'; position:absolute; left:0; color:var(--accent); font-weight:700; font-style:normal; }
    .dm ul.preds li { display:flex; flex-direction:column; gap:3px; border-top:1px solid var(--rule); padding-top:10px; }
    .dm ul.preds li:first-child { border-top:0; padding-top:0; }
    .dm .pt { font-size:14px; color:#e9e4d8; line-height:1.45; }
    .dm .pd { font-family:'Inter',sans-serif; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:var(--mute); }

    .dm .cur { display:flex; align-items:center; gap:10px; font-size:14px; color:#d8d2c4; margin-top:12px; }
    .dm .cur span { font-size:16px; }

    .dm .signal { display:flex; flex-direction:column; margin-top:12px; }
    .dm .sig { display:block; padding:10px 0; border-top:1px solid var(--rule); text-decoration:none; }
    .dm .sig:first-child { border-top:0; padding-top:2px; }
    .dm .st { display:block; font-family:'Spectral',serif; font-size:14.5px; color:#e9e4d8; line-height:1.4; }
    .dm .sig:hover .st { color:var(--accent2); }
    .dm .sm { display:block; font-family:'Inter',sans-serif; font-size:10.5px; color:var(--mute); margin-top:3px; letter-spacing:0.04em; text-transform:uppercase; }
    .dm .sm b { color:var(--accent); font-weight:700; }

    @media (max-width:820px) {
      .dm-grid { grid-template-columns:repeat(2,1fr); }
      .dm .c4 { grid-column:span 2; } .dm .c2 { grid-column:span 2; } .dm .r2 { grid-row:span 1; }
    }
    @media (max-width:520px) {
      .dm-grid { grid-template-columns:1fr; }
      .dm .c1, .dm .c2, .dm .c4 { grid-column:span 1; }
    }
  </style>
</Editorial>
