---
import Base from '../layouts/Base.astro';
// Friends-only Plex portal. Linked from emails, not from site nav.
// Live status + newest titles come from a public n8n endpoint (checks Plex identity + Tautulli recently-added).
const STATUS_API = 'https://n8n.allemanit.com/webhook/plex-status';
const VIDEO_URL = 'https://youtu.be/m-wiCr5uvXQ';
---
<Base title="AllemanIT Plex" description="Your AllemanIT Plex quick links and live server status.">
  <section class="container-x py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl font-extrabold text-white">AllemanIT Plex</h1>
      <p class="mt-3 text-white/65">Everything in one place: live server status, what's new, and how to watch or request.</p>

      <!-- STATUS -->
      <div class="card mt-8 flex items-center gap-4 p-6">
        <span id="status-dot" class="inline-block h-3.5 w-3.5 shrink-0 rounded-full bg-yellow-400"></span>
        <div>
          <div class="text-lg font-bold text-white">Plex Server</div>
          <div id="status-text" class="text-sm text-white/60">Checking status…</div>
        </div>
      </div>
      <p class="mt-2 text-xs text-white/40">If it shows offline, the server is likely rebooting. Give it a few minutes and try again, or let me know.</p>

      <!-- JUST ADDED -->
      <div id="recent-wrap" class="mt-8 hidden">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-orange">Just added</h2>
        <div id="recent-list" class="mt-3 flex flex-wrap gap-2"></div>
      </div>

      <!-- LINKS -->
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a href="https://app.plex.tv/desktop" target="_blank" rel="noopener" class="card p-6 transition hover:border-brand-orange">
          <div class="text-lg font-bold text-white">▶ Watch on Plex</div>
          <p class="mt-1 text-sm text-white/60">Open Plex in your browser or app and start watching.</p>
        </a>
        <a href="https://request.allemanit.com" target="_blank" rel="noopener" class="card p-6 transition hover:border-brand-orange">
          <div class="text-lg font-bold text-white">🍿 Request a movie or show</div>
          <p class="mt-1 text-sm text-white/60">Ask for a title and it gets added automatically.</p>
        </a>
        <a href={VIDEO_URL} target="_blank" rel="noopener" class="card p-6 transition hover:border-brand-orange">
          <div class="text-lg font-bold text-white">🎬 How to accept your invite</div>
          <p class="mt-1 text-sm text-white/60">60-second walkthrough for first-timers.</p>
        </a>
        <a href="/contact" class="card p-6 transition hover:border-brand-orange">
          <div class="text-lg font-bold text-white">✉ New here? Request access</div>
          <p class="mt-1 text-sm text-white/60">Not on the server yet? Send a quick request.</p>
        </a>
      </div>

      <!-- LIVE TV -->
      <div class="card mt-8 p-6">
        <div class="text-lg font-bold text-white">📺 Live TV channels (bonus)</div>
        <p class="mt-1 text-sm text-white/60">I also run custom live TV channels. Heads up: Plex only lets me share live TV with people who have a <strong class="text-white/80">Plex Pass</strong> and are added to my Plex Home. If you've got a Plex Pass and want to try it, just reach out and I'll set you up.</p>
      </div>

      <!-- NEWSLETTER -->
      <div class="card mt-4 p-6">
        <div class="text-lg font-bold text-white">✉ Weekly "what's new" email</div>
        <p class="mt-1 text-sm text-white/60">Every Monday I send a short roundup of new movies and shows from <strong class="text-white/80">plex-news@madeformeai.com</strong>. Add that address to your contacts and mark it "not junk" so it doesn't land in spam.</p>
      </div>

      <p class="mt-10 text-center text-xs text-white/40">AllemanIT Plex · questions? just reply to any of my emails.</p>
    </div>
  </section>

  <script define:vars={{ STATUS_API }}>
    (function () {
      const dot = document.getElementById('status-dot');
      const text = document.getElementById('status-text');
      fetch(STATUS_API, { cache: 'no-store' })
        .then((r) => r.json())
        .then((d) => {
          if (d.online) {
            dot.className = 'inline-block h-3.5 w-3.5 shrink-0 rounded-full bg-green-400';
            text.textContent = 'Online — ready to watch.';
          } else {
            dot.className = 'inline-block h-3.5 w-3.5 shrink-0 rounded-full bg-red-400';
            text.textContent = 'Offline — likely rebooting. Try again shortly.';
          }
          const recent = Array.isArray(d.recent) ? d.recent : [];
          if (recent.length) {
            const list = document.getElementById('recent-list');
            recent.slice(0, 8).forEach((it) => {
              const chip = document.createElement('span');
              chip.className = 'inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-white/80';
              const icon = it.type === 'movie' ? '🎬' : '📺';
              chip.textContent = icon + ' ' + it.title + (it.year ? ' (' + it.year + ')' : '');
              list.appendChild(chip);
            });
            document.getElementById('recent-wrap').classList.remove('hidden');
          }
        })
        .catch(() => {
          dot.className = 'inline-block h-3.5 w-3.5 shrink-0 rounded-full bg-yellow-400';
          text.textContent = 'Status unavailable right now — open Plex to check.';
        });
    })();
  </script>
</Base>
