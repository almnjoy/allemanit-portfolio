---
import Base from '../layouts/Base.astro';
import Thumb from '../components/Thumb.astro';
import { getCollection } from 'astro:content';
const all = (await getCollection('projects')).filter((p) => p.data.listed !== false).sort((a, b) => a.data.order - b.data.order);
const featured = all.filter((p) => p.data.featured);
const others = all.filter((p) => !p.data.featured);

const sites = [
  { name: 'almnjoy.dev', style: 'Retro Windows 98 desktop', url: 'https://almnjoy.dev' },
  { name: 'quickitprojects.com', style: 'Clean corporate / consulting', url: 'https://quickitprojects.com' },
  { name: 'madeformeai.com', style: 'Modern SaaS product', url: 'https://madeformeai.com' },
  { name: 'netadmintoolbox.com', style: 'Engineer utility site', url: 'https://netadmintoolbox.com' },
];
const links = [
  { href: 'https://github.com/almnjoy', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/dustin-alleman/', label: 'LinkedIn' },
  { href: 'https://www.youtube.com/@Almnjoy', label: 'YouTube' },
  { href: 'https://www.instagram.com/alleman_joyy/', label: 'Instagram' },
];
const credentials = [
  { k: 'Based in', v: 'Chicago, IL' },
  { k: 'Experience', v: '10+ yrs networking & IT' },
  { k: 'Certifications', v: 'CCNA · CWNA · Meraki Solutions Specialist' },
  { k: 'Education', v: 'B.S. IT, Western Governors University' },
  { k: 'Teaching', v: 'Instructor, Cisco Networking Academy' },
  { k: 'Service', v: 'U.S. Marine Corps veteran' },
];
---
<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="container-x grid items-center gap-6 pt-12 pb-8 lg:grid-cols-2 lg:gap-4">
      <div class="order-2 lg:order-1">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">Network engineer · builder · Chicago</p>
        <h1 class="text-6xl font-extrabold leading-[0.95] tracking-tight text-white sm:text-7xl">DUSTIN<br />ALLEMAN</h1>
        <p class="mt-6 max-w-md text-lg text-white/70">
          Ten-year network engineer, Marine Corps before that. By day I work in a FedRAMP network environment. The rest of the time I build AI tools, automation, and a homelab that runs like production.
        </p>
        <div class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm">
          {links.map((l) => (<a href={l.href} target="_blank" rel="noopener" class="text-white/55 underline-offset-4 hover:text-white hover:underline transition">{l.label}</a>))}
          <a href="/contact" class="text-white/55 underline-offset-4 hover:text-white hover:underline transition">Contact</a>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <img src="/me.jpg" alt="Dustin Alleman"
          class="mx-auto w-full max-w-md object-cover lg:max-w-none"
          style="aspect-ratio:4/5; -webkit-mask-image: radial-gradient(ellipse 78% 80% at 55% 42%, #000 50%, transparent 100%); mask-image: radial-gradient(ellipse 78% 80% at 55% 42%, #000 50%, transparent 100%);"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
        <div class="mx-auto hidden aspect-[4/5] w-full max-w-md flex-col items-center justify-center gap-3 rounded-3xl border border-dashed border-white/15" style="display:none">
          <img src="/logo-mark.png" class="h-12 w-12 opacity-40" alt="" />
          <span class="text-sm text-white/40">Your photo → public/me.jpg</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT / BACKGROUND -->
  <section id="about" class="container-x py-10">
    <div class="grid gap-8 lg:grid-cols-[1fr_1.2fr]">
      <div>
        <h2 class="text-2xl font-bold text-white">About</h2>
        <p class="mt-4 text-white/70 leading-relaxed">
          I'm Dustin. I've spent over a decade in IT: support, help desk, networking, engineering, infrastructure. It started long before the paycheck. I was the kid taking computers apart, downloading games and music, breaking things and figuring out how to fix them. Too many years of World of Warcraft, still a PC gamer. That curiosity turned into the career.
        </p>
        <p class="mt-4 text-white/70 leading-relaxed">
          I did IT in the Marine Corps, carried it through a few companies after that, and these days I work on Cisco networking in a FedRAMP environment. I came up on the hands-on side: packet captures, escalations, enterprise gear. The goal was always to architect networks, not just support them, and to build the tools I wished I had along the way.
        </p>
        <p class="mt-4 text-white/70 leading-relaxed">
          So I build. Dashboards, AI agents, automation, a homelab that grew from scavenged gear into something that runs like production. A lot of it points at one goal: moving into a sales engineer role, which is why so many of these projects are about proving a thing out and explaining it clearly. I also teach CCNA-level networking at colleges around Chicago, which is some of the most rewarding work I do.
        </p>
        <p class="mt-4 text-white/50 leading-relaxed text-sm">
          Off the clock: Chicago lakefront skates, biking, anything outdoors, a Jeep with a permanent project list, and whatever the lab breaks that week.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {credentials.map((c) => (
          <div class="card p-4">
            <p class="text-xs uppercase tracking-wider text-white/40">{c.k}</p>
            <p class="mt-1 text-white/85">{c.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED -->
  <section id="projects" class="container-x py-10">
    <h2 class="mb-6 text-2xl font-bold text-white">Featured projects</h2>
    <div class="grid gap-5 sm:grid-cols-2">
      {featured.map((p) => (
        <a href={`/projects/${p.slug}`} class="card group block overflow-hidden">
          <Thumb image={p.data.image} alt={p.data.title} />
          <div class="p-5">
            <div class="mb-2 flex items-center justify-between"><h3 class="text-lg font-bold text-white">{p.data.title}</h3><span class="tag">{p.data.status}</span></div>
            <p class="text-sm text-white/70">{p.data.summary}</p>
            <div class="mt-3 flex flex-wrap gap-1.5">{p.data.tags.map((t) => (<span class="tag">{t}</span>))}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- OTHER -->
  <section class="container-x py-10">
    <h2 class="mb-6 text-2xl font-bold text-white">Other projects</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {others.map((p) => (
        <a href={`/projects/${p.slug}`} class="card group block p-5">
          <div class="mb-1.5 flex items-center justify-between gap-2"><h3 class="font-bold text-white">{p.data.title}</h3><span class="tag shrink-0">{p.data.status}</span></div>
          <p class="text-sm text-white/65">{p.data.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- SITES -->
  <section class="container-x py-10">
    <h2 class="mb-2 text-2xl font-bold text-white">Sites I have designed</h2>
    <p class="mb-6 text-white/60">Different builds, different design languages.</p>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {sites.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" class="card group block overflow-hidden">
          <Thumb alt={s.name} />
          <div class="p-4"><h3 class="font-bold text-white">{s.name}</h3><p class="text-sm text-white/60">{s.style}</p></div>
        </a>
      ))}
    </div>
  </section>

  <!-- CONTENT -->
  <section id="content" class="container-x py-10">
    <div class="card flex flex-col items-start justify-between gap-5 p-7 sm:flex-row sm:items-center">
      <div><h2 class="text-xl font-bold text-white">Follow the build</h2><p class="mt-1 text-white/60">Homelab, AI agents, networking, and automation.</p></div>
      <div class="flex flex-wrap gap-3">{links.map((l) => (<a href={l.href} target="_blank" rel="noopener" class="btn btn-ghost text-sm">{l.label}</a>))}</div>
    </div>
  </section>

  <!-- QUIET CONTACT -->
  <section class="container-x py-10">
    <p class="text-white/60">Need lab, media, or Nextcloud access, or want to talk shop? <a href="/contact" class="font-semibold text-white underline underline-offset-4 hover:text-brand-orange">Get in touch</a>.</p>
  </section>
</Base>
